<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.jboss</groupId>
        <artifactId>jboss-parent</artifactId>
        <version>52</version>
    </parent>

    <groupId>org.wildfly.security.hashicorp.vault</groupId>
    <artifactId>wildfly-elytron-hashicorp-vault</artifactId>
    <version>1.0.0.Alpha6-SNAPSHOT</version>

    <name>WildFly Elytron HashiCorp Vault Integration</name>
    <description>An integration library that provides WildFly Elytron credential store backed by HashiCorp Vault.</description>
    <url>https://wildfly-security.github.io/wildfly-elytron/</url>

    <packaging>jar</packaging>
    <properties>
        <jdk.min.version>25</jdk.min.version>
        <maven.compiler.release>17</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        
        <!-- Test JDK selection (for multi-version testing with toolchains) -->
        <jdk.test.version>25</jdk.test.version>
        <jdk.test.vendor>temurin</jdk.test.vendor>
        <version.wildfly.elytron>2.8.3.Final</version.wildfly.elytron>
        <version.vault.java.driver>6.2.1</version.vault.java.driver>
        <version.metainf-services>1.11</version.metainf-services>
        <version.org.testcontainers>2.0.2</version.org.testcontainers>
        <version.org.junit>6.0.0</version.org.junit>
        <version.io.smallrye.certs>0.9.2</version.io.smallrye.certs>
        <version.io.rest-assured>5.5.6</version.io.rest-assured>
        <version.io.rest-assured.json-path>5.5.5</version.io.rest-assured.json-path>
        <version.maven.surefire.plugin>3.5.3</version.maven.surefire.plugin>
        <version.org.bitbucket.b_c.jose4j>0.9.6</version.org.bitbucket.b_c.jose4j>

        <!-- Nexus Settings -->
        <nexus.repository.staging>wildfly-staging</nexus.repository.staging>
        <nexus.staging.tag>wildfly-elytron-hashicorp-vault-${project.version}</nexus.staging.tag>
        <nexus.repository.release>wildfly-security</nexus.repository.release>
    </properties>

    <developers>
        <developer>
            <name>Diana Krepinska</name>
            <email>diavilko@gmail.com</email>
            <organization>WildFly</organization>
            <organizationUrl>https://www.wildfly.org/</organizationUrl>
        </developer>
    </developers>

    <scm>
        <connection>scm:git:git@github.com:wildfly-security-incubator/wildfly-elytron-hashicorp-vault.git</connection>
        <developerConnection>scm:git:git@github.com:wildfly-security-incubator/wildfly-elytron-hashicorp-vault</developerConnection>
        <url>https://github.com/wildfly-security-incubator/wildfly-elytron-hashicorp-vault</url>
      <tag>HEAD</tag>
    </scm>

    <dependencyManagement>
      <dependencies>
        <dependency>
          <groupId>org.testcontainers</groupId>
          <artifactId>testcontainers-bom</artifactId>
	  <version>${version.org.testcontainers}</version>
          <type>pom</type>
          <scope>import</scope>
        </dependency>
      </dependencies>
    </dependencyManagement>

    <dependencies>
        <!-- Vault Java Driver -->
        <dependency>
            <groupId>io.github.jopenlibs</groupId>
            <artifactId>vault-java-driver</artifactId>
            <version>${version.vault.java.driver}</version>
        </dependency>

        <dependency>
            <groupId>org.kohsuke.metainf-services</groupId>
            <artifactId>metainf-services</artifactId>
            <version>${version.metainf-services}</version>
        </dependency>

        <dependency>
            <groupId>org.wildfly.security</groupId>
            <artifactId>wildfly-elytron-credential</artifactId>
            <version>${version.wildfly.elytron}</version>
        </dependency>
        <dependency>
            <groupId>org.wildfly.security</groupId>
            <artifactId>wildfly-elytron-credential-store</artifactId>
            <version>${version.wildfly.elytron}</version>
        </dependency>
        <dependency>
            <groupId>org.wildfly.security</groupId>
            <artifactId>wildfly-elytron-password-impl</artifactId>
            <version>${version.wildfly.elytron}</version>
        </dependency>


        <!-- Test dependencies-->
        <!-- https://mvnrepository.com/artifact/org.testcontainers/vault -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-vault</artifactId>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.junit</groupId>
            <artifactId>junit-bom</artifactId>
            <version>${version.org.junit}</version>
            <type>pom</type>
            <scope>import</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${version.org.junit}</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>io.smallrye.certs</groupId>
            <artifactId>smallrye-certificate-generator</artifactId>
            <version>${version.io.smallrye.certs}</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.bitbucket.b_c</groupId>
            <artifactId>jose4j</artifactId>
            <version>${version.org.bitbucket.b_c.jose4j}</version>
            <scope>test</scope>
        </dependency>

        <!-- https://mvnrepository.com/artifact/io.rest-assured/rest-assured -->
        <dependency>
            <groupId>io.rest-assured</groupId>
            <artifactId>rest-assured</artifactId>
            <version>${version.io.rest-assured}</version>
            <scope>test</scope>
        </dependency>

        <!-- https://mvnrepository.com/artifact/io.rest-assured/json-path -->
        <dependency>
            <groupId>io.rest-assured</groupId>
            <artifactId>json-path</artifactId>
            <version>${version.io.rest-assured.json-path}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>${version.maven.surefire.plugin}</version>
                    <configuration>
                        <environmentVariables>
                            <api.version>1.44</api.version>
                        </environmentVariables>
                        <includes>
                            <include>**/*TestCase.java</include>
                        </includes>
                        <!-- Toolchains support for multi-version testing -->
                        <jdkToolchain>
                            <version>${jdk.test.version}</version>
                            <vendor>${jdk.test.vendor}</vendor>
                        </jdkToolchain>
                    </configuration>
                </plugin>

                <plugin>
                    <!-- Release Plugin Configuration -->
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-release-plugin</artifactId>
                    <configuration>
                        <!-- Prepare -->
                        <pushChanges>false</pushChanges>
                        <preparationProfiles>jboss-release</preparationProfiles>
                        <arguments>-DskipTests</arguments>
                        <!-- Perform -->
                        <localCheckout>true</localCheckout>
                        <releaseProfiles>jboss-release</releaseProfiles>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>
    
    <repositories>
        <repository>
            <id>public-jboss</id>
            <name>Public JBoss Repository Group</name>
            <url>https://repository.jboss.org/nexus/repository/public-jboss/</url>
        </repository>
    </repositories>
    <pluginRepositories>
        <pluginRepository>
            <id>public-jboss-plugins</id>
            <name>Public JBoss Repository Group</name>
            <url>https://repository.jboss.org/nexus/repository/public-jboss/</url>
        </pluginRepository>
    </pluginRepositories>

    <profiles>
        <!-- Profile for comprehensive multi-version testing -->
        <!-- Tests with Java 17, 21, and 25 sequentially -->
        <!-- Usage: mvn install -Ptest-all-versions -->
        <!-- Optional: mvn install -Ptest-all-versions -Djdk.test.vendor=semeru -->
        <profile>
            <id>test-all-versions</id>
            <properties>
                <!-- Default to Temurin if vendor not specified -->
                <jdk.test.vendor>temurin</jdk.test.vendor>
            </properties>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <executions>
                            <!-- Test with Java 17 -->
                            <execution>
                                <id>test-java-17</id>
                                <goals>
                                    <goal>test</goal>
                                </goals>
                                <configuration>
                                    <jdkToolchain>
                                        <version>17</version>
                                        <vendor>${jdk.test.vendor}</vendor>
                                    </jdkToolchain>
                                    <reportsDirectory>${project.build.directory}/surefire-reports-java17-${jdk.test.vendor}</reportsDirectory>
                                </configuration>
                            </execution>

                            <!-- Test with Java 21 -->
                            <execution>
                                <id>test-java-21</id>
                                <goals>
                                    <goal>test</goal>
                                </goals>
                                <configuration>
                                    <jdkToolchain>
                                        <version>21</version>
                                        <vendor>${jdk.test.vendor}</vendor>
                                    </jdkToolchain>
                                    <reportsDirectory>${project.build.directory}/surefire-reports-java21-${jdk.test.vendor}</reportsDirectory>
                                </configuration>
                            </execution>

                            <!-- Test with Java 25 -->
                            <execution>
                                <id>test-java-25</id>
                                <goals>
                                    <goal>test</goal>
                                </goals>
                                <configuration>
                                    <jdkToolchain>
                                        <version>25</version>
                                        <vendor>${jdk.test.vendor}</vendor>
                                    </jdkToolchain>
                                    <reportsDirectory>${project.build.directory}/surefire-reports-java25-${jdk.test.vendor}</reportsDirectory>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
